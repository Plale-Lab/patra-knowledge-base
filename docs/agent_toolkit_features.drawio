        <mxCell id="9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede7f6;strokeColor=#5e35b1;align=left;spacingLeft=10;spacingTop=6;verticalAlign=top;" value="&lt;b&gt;7. Artifact persistence &amp;amp; admission&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;PostgreSQL &lt;i&gt;generated_dataset_artifacts&lt;/i&gt; · CSV/schema downloads&lt;br/&gt;&lt;i&gt;POST …/submit-review&lt;/i&gt; → admin &lt;i&gt;submission_queue&lt;/i&gt; (pool admission)&lt;/font&gt;" vertex="1">
