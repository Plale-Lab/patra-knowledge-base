        <mxCell id="6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#263238;align=left;spacingLeft=10;spacingTop=6;verticalAlign=top;" value="&lt;b&gt;4. Rank &amp;amp; align&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;&lt;i&gt;src/hybrid_schema_matcher&lt;/i&gt; (+ optional OpenAI-compatible LLM rerank)&lt;br/&gt;&lt;i&gt;POST /agent-tools/paper-schema-search&lt;/i&gt; — embeds per-candidate feasibility summary&lt;/font&gt;" vertex="1">
          <mxGeometry height="68" width="400" x="40" y="336" as="geometry" />
