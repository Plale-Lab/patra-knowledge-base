        <mxCell id="2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontStyle=1;fillColor=#eceff1;strokeColor=#546e7a;" value="PATRA agent toolkit pipeline — methods / figure caption (T.B.D.)" vertex="1">
          <mxGeometry height="48" width="747" x="40" y="32" as="geometry" />
        </mxCell>
        <mxCell id="3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#263238;align=left;spacingLeft=10;spacingTop=6;verticalAlign=top;" value="&lt;b&gt;1. Document in&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Exactly one of: server path, URL, or pasted text → &lt;i&gt;patra_agent_service.extract_schema&lt;/i&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="56" width="400" x="40" y="100" as="geometry" />
        </mxCell>
        <mxCell id="4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#f57f17;align=left;spacingLeft=10;spacingTop=6;verticalAlign=top;" value="&lt;b&gt;2. Query schema extraction&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;&lt;i&gt;src/paper_schema_parser&lt;/i&gt; (DOCX / MD / JSON); HTML tables in-service → &lt;i&gt;machine_schema&lt;/i&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="62" width="400" x="40" y="176" as="geometry" />
        </mxCell>
        <mxCell id="5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1565c0;align=left;spacingLeft=10;spacingTop=6;verticalAlign=top;" value="&lt;b&gt;3. Public schema pool&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;&lt;i&gt;src/patra_schema_pool&lt;/i&gt; · cache &lt;i&gt;.patra-agent-cache/&lt;/i&gt; · &lt;i&gt;GET /agent-tools/schema-pool&lt;/i&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="58" width="400" x="40" y="258" as="geometry" />
