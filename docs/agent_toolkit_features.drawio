        <mxCell id="7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;align=left;spacingLeft=10;spacingTop=6;verticalAlign=top;" value="&lt;b&gt;5. Missing-column feasibility&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;&lt;i&gt;src/missing_column_derivation&lt;/i&gt; — direct / derivable-with-provenance / rejected&lt;br/&gt;&lt;i&gt;POST /agent-tools/missing-column-analysis&lt;/i&gt; (per chosen candidate)&lt;/font&gt;" vertex="1">
          <mxGeometry height="64" width="400" x="40" y="424" as="geometry" />
        </mxCell>
        <mxCell id="8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#ad1457;align=left;spacingLeft=10;spacingTop=6;verticalAlign=top;" value="&lt;b&gt;6. Bounded synthesis (optional)&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px&quot;&gt;&lt;i&gt;patra_synthesis_service&lt;/i&gt;: A plan (opt. LLM) → B deterministic exec → C validation → D materialize&lt;br/&gt;&lt;i&gt;POST /agent-tools/generate-synthesized-dataset&lt;/i&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="72" width="400" x="40" y="508" as="geometry" />
